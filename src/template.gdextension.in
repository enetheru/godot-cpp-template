[configuration]

entry_symbol = "${ENTRY_SYMBOL}"
compatibility_minimum = "${COMPATIBILITY_MINIMUM}"
;compatibility_maximum = "${COMPATIBILITY_MAXIMUM}"
;reloadable = "${ENABLE_HOT_RELOAD}"
;autodetect_library_prefix = "${AUTO_LIB_PREFIX}"

[libraries]
${FEATURE_FLAGS} = "${LIBRARY_FILENAME}"

[icons]
;iconkey = <path>